# Server
PORT=8080

# Proxmox VE API (https://pve.proxmox.com/pve-docs/api-viewer)
# Use API token for service accounts (Datacenter -> Permissions -> API Tokens)
PROXMOX_HOST=your-proxmox-host
PROXMOX_PORT=8006
PROXMOX_USER=svc_WatchTower
PROXMOX_REALM=pam
PROXMOX_TOKEN_ID=your-token-name
PROXMOX_TOKEN_SECRET=your-token-secret-uuid

# OpenVPN management (optional, for Connected Devices)
OPENVPN_HOST=192.168.68.66
OPENVPN_PORT=7505
OPENVPN_PASSWORD=
