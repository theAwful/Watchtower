# Server
PORT=8080

# HTTPS (optional): set both to serve over https://IP:port (self-signed or real certs)
# SSL_CERT_PATH=/path/to/fullchain.pem
# SSL_KEY_PATH=/path/to/privkey.pem

# Proxmox VE API (https://pve.proxmox.com/pve-docs/api-viewer)
# Use API token for service accounts (Datacenter -> Permissions -> API Tokens)
PROXMOX_HOST=your-proxmox-host
PROXMOX_PORT=8006
PROXMOX_USER=svc_WatchTower
PROXMOX_REALM=pam
PROXMOX_TOKEN_ID=your-token-name
PROXMOX_TOKEN_SECRET=your-token-secret-uuid
# Password for PROXMOX_USER (e.g. svc_WatchTower). Used by /api/proxmox/set-session to log in to Proxmox (e.g. https://172.22.9.10:8006) and set PVEAuthCookie so noVNC works. Quote if password has special chars: PROXMOX_PASSWORD="your-password"
PROXMOX_PASSWORD=your-proxmox-password
# Optional: if Proxmox is reverse-proxied under same domain, set this so console URL uses it.
# PROXMOX_PUBLIC_URL=https://your-proxmox-host:8006

# Login (single user; optional)
# WATCHTOWER_USER=admin
# WATCHTOWER_PASSWORD=your-secure-password
# SESSION_SECRET=optional-random-secret

# OpenVPN management (optional, for Connected Devices)
OPENVPN_HOST=192.168.68.66
OPENVPN_PORT=7505
OPENVPN_PASSWORD=
