# Copy this file to .env and update with your values

# Server configuration (only needed for local development, not Docker)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# Database configuration
DB_HOST=postgres  # Use 'postgres' for Docker, 'localhost' for local development
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=dashboard
DB_SSL_MODE=disable

# Frontend port (default: 80)
FRONTEND_PORT=80

# Tailscale OAuth configuration
# Create OAuth client at: https://login.tailscale.com/admin/settings/oauth
TAILSCALE_CLIENT_ID=your_client_id_here
TAILSCALE_CLIENT_SECRET=your_client_secret_here
TAILSCALE_REDIRECT_URI=https://your-domain.com/api/oauth/callback
TAILSCALE_API_URL=https://api.tailscale.com

# OAuth settings
OAUTH_REFRESH_BUFFER=10m

# Jenkins integration (optional)
# Set to false to disable Jenkins integration
JENKINS_ENABLED=true

# Bitwarden CLI configuration
# Path to the host's Bitwarden CLI config directory
# This will be mounted into the container to persist authentication
BW_CONFIG=/root/.config/Bitwarden CLI