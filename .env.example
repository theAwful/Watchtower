# Server
PORT=8080

# HTTPS (optional): set both to serve over https://IP:port (self-signed or real certs)
# SSL_CERT_PATH=/path/to/fullchain.pem
# SSL_KEY_PATH=/path/to/privkey.pem
# Optional chain/intermediate (some clients need this): SSL_CA_PATH=/path/to/chain.pem

# When serving HTTPS in production, set so session cookies use Secure:
# HTTPS=1

# Proxmox VE API (https://pve.proxmox.com/pve-docs/api-viewer)
# Use API token for service accounts (Datacenter -> Permissions -> API Tokens)
PROXMOX_HOST=your-proxmox-host
PROXMOX_PORT=8006
PROXMOX_USER=svc_WatchTower
PROXMOX_REALM=pam
PROXMOX_TOKEN_ID=your-token-name
PROXMOX_TOKEN_SECRET=your-token-secret-uuid
# Password for PROXMOX_USER (e.g. svc_WatchTower). Used by /api/proxmox/set-session to log in to Proxmox (e.g. https://172.22.9.10:8006) and set PVEAuthCookie so noVNC works. Quote if password has special chars: PROXMOX_PASSWORD="your-password"
PROXMOX_PASSWORD=your-proxmox-password
# Optional: if Proxmox is reverse-proxied under same domain, set this so console URL uses it.
# PROXMOX_PUBLIC_URL=https://your-proxmox-host:8006

# Proxmox group whose members appear in the Create VM "Operator" dropdown (Datacenter → Permissions → Groups).
# WATCHTOWER_PROXMOX_OPERATORS_GROUP=VM_Operators

# Watchtower only lists and controls VMs in this Proxmox pool (API token may still have full datacenter access).
# WATCHTOWER_PROXMOX_POOL=VM-Operators_Pool
# Break-glass: disable pool filtering (dev / full visibility)
# WATCHTOWER_PROXMOX_POOL_ALLOW_ALL=1

# Tag added when a user flags a VM for deletion in the UI (default ToBeDeleted). Infra removes VMs with this tag in Proxmox.
# WATCHTOWER_VM_DELETE_REQUEST_TAG=ToBeDeleted

# Clone placement (round-robin among online nodes; skip nodes over these thresholds). See docs/pages/proxmox.md.
# WATCHTOWER_PLACEMENT_MAX_CPU=0.9
# WATCHTOWER_PLACEMENT_MAX_MEM_UTIL=0.9
# WATCHTOWER_PLACEMENT_MAX_DISK_UTIL=0.85
# WATCHTOWER_PLACEMENT_MIN_FREE_MEM_BYTES=0

# Login (single user; optional)
# WATCHTOWER_USER=admin
# WATCHTOWER_PASSWORD=your-secure-password
# SESSION_SECRET=optional-random-secret

# OpenVPN management (optional, for Connected Devices)
OPENVPN_HOST=192.168.68.66
OPENVPN_PORT=7505
OPENVPN_PASSWORD=
